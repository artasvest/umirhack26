# Скопируйте в .env в корне репозитория и задайте свои значения:
#   cp .env.example .env   (Linux/macOS)
#   copy .env.example .env   (Windows)
#
# Для Docker: хост БД в DATABASE_URL всегда db (имя сервиса в docker-compose).
# Замените YOUR_SERVER_IP на публичный IP сервера (без домена) в CORS и FRONTEND_PUBLIC_URL.

# --- Порт HTTP (nginx → хост) ---
HTTP_PORT=80

# --- PostgreSQL (сервис db) — пароль должен совпадать с DATABASE_URL ниже ---
POSTGRES_USER=umir
POSTGRES_PASSWORD=change-this-strong-password
POSTGRES_DB=umir_db

# --- Backend (тот же пароль, что в POSTGRES_PASSWORD) ---
DATABASE_URL=postgresql+asyncpg://umir:change-this-strong-password@db:5432/umir_db

JWT_SECRET=change-me-to-a-long-random-string
ADMIN_EMAIL=admin@studio.local
ADMIN_PASSWORD=change-admin-password
ADMIN_NAME=Администратор

# Доступ к фронту по IP (через запятую, без пробелов после запятой можно):
CORS_ORIGINS=http://YOUR_SERVER_IP
FRONTEND_PUBLIC_URL=http://YOUR_SERVER_IP

TELEGRAM_BOT_TOKEN=
TELEGRAM_BOT_USERNAME=
TELEGRAM_MANAGER_CHAT_ID=

# Опционально: GigaChat, Groq, Hugging Face — см. backend/.env.example
