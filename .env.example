# =============================================
# ПРИМЕР КОНФИГУРАЦИИ — скопируй в .env и заполни своими значениями
# =============================================

# Порт на котором будет доступен сайт
HTTP_PORT=80

# ---- База данных ----
POSTGRES_USER=your_db_user
POSTGRES_PASSWORD=your_strong_password
POSTGRES_DB=your_db_name

# Строка подключения к БД (замени user, password, host, dbname)
DATABASE_URL=postgresql+asyncpg://your_db_user:your_strong_password@your_host:5432/your_db_name

# ---- Безопасность ----
# Длинная случайная строка для подписи JWT токенов (минимум 32 символа)
JWT_SECRET=your-very-long-random-secret-string

# ---- Администратор ----
ADMIN_EMAIL=admin@yourdomain.com
ADMIN_PASSWORD=your_admin_password
ADMIN_NAME=Your Name

# ---- CORS и публичный URL ----
# Через запятую можно указать несколько origins
CORS_ORIGINS=https://yourdomain.com
FRONTEND_PUBLIC_URL=https://yourdomain.com

# ---- Telegram бот (опционально) ----
# Получить токен можно у @BotFather в Telegram
TELEGRAM_BOT_TOKEN=
TELEGRAM_BOT_USERNAME=
# ID чата или группы куда будут приходить заявки
TELEGRAM_MANAGER_CHAT_ID=