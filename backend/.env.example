# Скопируйте в .env и подправьте:
#   copy .env.example .env   (Windows)
#   cp .env.example .env     (macOS/Linux)

# PostgreSQL + asyncpg (обязательно для текущего бэкенда).
DATABASE_URL=postgresql+asyncpg://USER:PASSWORD@localhost:5432/DBNAME

JWT_SECRET=change-me-to-long-random
TELEGRAM_BOT_TOKEN=
# Имя бота без @ (как в t.me/...) — для ссылки «Войти в Telegram» из кабинета.
TELEGRAM_BOT_USERNAME=
# Опционально: дублировать уведомления о новых заявках в общий чат (id группы).
TELEGRAM_MANAGER_CHAT_ID=
# Бот: python bot_worker.py — привязка по ссылке из кабинета; пул и напоминания в личку.
CORS_ORIGINS=http://localhost:5173,http://127.0.0.1:5173
ADMIN_EMAIL=admin@studio.local
ADMIN_PASSWORD=admin123
FRONTEND_PUBLIC_URL=http://localhost:5173

# GigaChat (опционально): GIGACHAT_CREDENTIALS (Base64) или пара:
# GIGACHAT_CLIENT_ID=
# GIGACHAT_CLIENT_SECRET=
GIGACHAT_SCOPE=GIGACHAT_API_PERS
GIGACHAT_MODEL=GigaChat
# GIGACHAT_SUMMARY_TIMEOUT_SEC=20
# GIGACHAT_VERIFY_SSL=false

# Транскрипция голосовых заметок (Whisper). Достаточно одного провайдера.
# Groq (рекомендуется с ключом gsk_...): https://console.groq.com
# GROQ_API_KEY=
# GROQ_TRANSCRIPTION_MODEL=whisper-large-v3-turbo
# Hugging Face (отдельный токен hf_..., не Groq): https://huggingface.co/settings/tokens
# HUGGINGFACE_API_TOKEN=
# HUGGINGFACE_WHISPER_URL=https://api-inference.huggingface.co/models/openai/whisper-large-v3-turbo
# WHISPER_PROVIDER=auto
